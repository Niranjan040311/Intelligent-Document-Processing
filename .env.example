# DocScan environment configuration — TEMPLATE (safe to commit).
# Copy this file to ".env" and fill in your real values.
# The real ".env" is git-ignored and must NEVER be committed.
#
# The LLM fallback (GPT-4.1) only runs when keyword extraction can't find a
# field. If NEITHER block below is configured, DocScan stays fully offline.

# ── Option A: Azure OpenAI (recommended for Synergech / internal-confidential data) ──
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4.1
# AZURE_OPENAI_API_VERSION=2024-10-21

# ── Option B: OpenAI direct ──
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1
